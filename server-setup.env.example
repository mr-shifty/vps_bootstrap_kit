# Copy to server-setup.env and edit values.

# Required for secure setup if PasswordAuthentication is disabled.
ADMIN_PUBLIC_KEY="ssh-ed25519 AAAA... your_email@example.com"

# Admin user to create/add to sudo group.
ADMIN_USER="admin"

# SSH hardening.
SSH_PORT="2222"
PANEL_IP="203.0.113.10"
DISABLE_ROOT_LOGIN="yes"
DISABLE_PASSWORD_AUTH="yes"

# Mandatory TCP ports to allow from anywhere:
# 14228, 80, 443, 8443, 1234
AVAILABLE_TCP_PORTS="14228 80 443 8443 1234"

# Choose which ports to open from AVAILABLE_TCP_PORTS.
# Example: open all
OPEN_TCP_PORTS="14228 80 443 8443 1234"
# Example: open only web
# OPEN_TCP_PORTS="80 443"

# ACME / Let's Encrypt via acme.sh
ENABLE_ACME_SSL="no"
ACME_EMAIL="admin@example.com"
ACME_DOMAIN="example.com"

# Optional extra domains (SAN), space-separated:
# ACME_ALT_DOMAINS="www.example.com api.example.com"
ACME_ALT_DOMAINS=""

# CA for acme.sh (letsencrypt, zerossl, etc.)
ACME_CA="letsencrypt"

# Key length examples: ec-256, ec-384, 2048, 4096
ACME_KEY_LENGTH="ec-256"

# Where to install resulting cert files
ACME_CERT_PATH="/etc/ssl/acme/example.com/cert.pem"
ACME_KEY_PATH="/etc/ssl/acme/example.com/key.pem"
ACME_FULLCHAIN_PATH="/etc/ssl/acme/example.com/fullchain.pem"
ACME_CA_CERT_PATH="/etc/ssl/acme/example.com/ca.pem"

# Optional command to reload your service after cert install.
# Example: ACME_RELOAD_CMD="systemctl reload nginx"
ACME_RELOAD_CMD=""

# Optional hooks (for example stop/start web server if port 80 is busy):
# ACME_PRE_HOOK="systemctl stop nginx"
# ACME_POST_HOOK="systemctl start nginx"
ACME_PRE_HOOK=""
ACME_POST_HOOK=""

# System settings.
TIMEZONE="Europe/Moscow"
SET_HOSTNAME="my-server"

# Security components.
ENABLE_UFW="yes"
ENABLE_FAIL2BAN="yes"
ENABLE_AUTO_UPDATES="yes"

# Swap size in GB. 0 means skip swap creation.
CREATE_SWAP_GB="2"
